# SQL Server Connection Configuration

# Transport selection: "stdio" (default) or "http"
MCP_TRANSPORT=stdio
# HTTP transport listen port (only used when MCP_TRANSPORT=http, default 8000)
PORT=8000
# Optional DNS-rebinding protection: comma-separated allowlist of Host headers
# MCP_ALLOWED_HOSTS=mcp.internal.example.com,127.0.0.1

# Required - SQL Server credentials
SQLSERVER_USER=your-username
SQLSERVER_PASSWORD=your-password

# For docker-compose: the password is read from SQL_PWD
# SQL_PWD=your-password

# Server connection details
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=master

# Security settings
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_CERT=true

# Performance settings  
SQLSERVER_CONNECTION_TIMEOUT=30000
SQLSERVER_REQUEST_TIMEOUT=60000
SQLSERVER_MAX_ROWS=1000

# Example configurations for different environments:

# Azure SQL Database
# SQLSERVER_HOST=your-server.database.windows.net
# SQLSERVER_ENCRYPT=true
# SQLSERVER_TRUST_CERT=false

# On-premises SQL Server with self-signed certificates
# SQLSERVER_HOST=sql-server.company.com
# SQLSERVER_ENCRYPT=true
# SQLSERVER_TRUST_CERT=true

# Local development (SQL Server Express)
# SQLSERVER_HOST=localhost\\SQLEXPRESS
# SQLSERVER_ENCRYPT=false
# SQLSERVER_TRUST_CERT=true